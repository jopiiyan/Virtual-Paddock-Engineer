# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Supabase (pgvector store) — required for ingestion, retrieval, and the API ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Ingestion scope (optional; backend.ingestion defaults) ---
INGEST_YEAR=2025
INGEST_GP=Silverstone

# --- RAGAS judge (optional; only needed to fill the RAGAS columns in EVALUATION.md) ---
# Independent of the llama3.2 generator by design (see docs/DECISIONS.md D2).
# Needs Generative Language API quota; free-tier daily limits may throttle a full run.
GEMINI_API_KEY=your-gemini-api-key
